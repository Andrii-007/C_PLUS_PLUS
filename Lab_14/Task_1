#include <iostream>
#include <string>
#include <ctime>
#include <cstdlib>
#include <iomanip>
using namespace std;

int main()
{
float *arr = new float [5];
int min=-2, max=2;
int even=0, odd=0;
 srand(time(NULL));
 for (int i = 0; i < 5; i++) {
   arr[i] = min+(max-min)*(rand() % 101)/100.0;
   cout<<fixed<<setprecision(2)<<arr[i]<<"  ";
   if(arr[i]<0) odd++;
   else even++;
}
cout<<endl<<"Amount of odd numbers: "<<odd<<endl;
cout<<"Amount of even numbers: "<<even;

delete [] arr;

return 0;
}
