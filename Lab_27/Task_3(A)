#include <iostream>
using namespace std;

const int DivideByZero = 111;

float internaldiv(float arg1, float arg2) {
    if (arg2 == 0.0f)
        throw DivideByZero;
    return arg1 / arg2;
}

float div(float arg1, float arg2) {
    try {
        return internaldiv(arg1, arg2);
    }
    catch (int errorCode) {
        if (errorCode == DivideByZero) {
            cout << "[Error inside div()]: Division by zero detected!" << endl;
        }
        throw; 
    }
}

int main(void) {
    float a, b;
    while (cin >> a) {
        cin >> b;
        try {
            float r = div(a, b);
            cout << r << endl;
        }
        catch (int errorCode) {
            cout << "Are you kidding me? (Caught in main)" << endl;
        }
    }
    return 0;
}
