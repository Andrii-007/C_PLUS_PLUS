#include <iostream>
using namespace std;

const int DivideByZero = 111;

float div(float arg1, float arg2) {
    if (arg2 == 0.0f) {
        throw DivideByZero; 
    }
    return arg1 / arg2;
}

int main(void) {
    float a, b;
    while (cin >> a) {
        cin >> b;
        try {
            float r = div(a, b);
            cout << r << endl;
        }
        catch (int errorCode) {
            if (errorCode == DivideByZero) {
                cout << "Are you kidding me? You cannot divide by zero." << endl;
            }
        }
    }
    return 0;
}
