#include <iostream>
#include <string>
#include <map>
#include <sstream>

using namespace std;

int main()
{
    string values;
    getline(cin, values);

    string text_template;
    getline(cin, text_template);

    map<string, string> value_map;
    stringstream ss(values);
    string pair;

    while (getline(ss, pair, ',')) {
        size_t equal_pos = pair.find('=');
        if (equal_pos != string::npos) {
            string key = pair.substr(0, equal_pos);
            string value = pair.substr(equal_pos + 1);
            value_map[key] = value;
        }
    }

    size_t start_pos = 0;
    
    while ((start_pos = text_template.find('[', start_pos)) != string::npos) {
        size_t end_pos = text_template.find(']', start_pos);
        
        if (end_pos != string::npos) {
            string placeholder = text_template.substr(start_pos + 1, end_pos - start_pos - 1);
            
            if (value_map.find(placeholder) != value_map.end()) {
                string replacement = value_map[placeholder];
                
                text_template.replace(start_pos, end_pos - start_pos + 1, replacement);
                
                start_pos += replacement.length();
            } else {
                start_pos += 1;
            }
        } else {
            break;
        }
    }

    cout << text_template << "\n";

    return 0;
}
