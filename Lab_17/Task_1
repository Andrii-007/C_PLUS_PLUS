#include <iostream>
#include <cmath>

using namespace std;

bool isPrime(int num) {
if (num < 2) return false;
    int check=0;
    for (int i=2; i<=sqrt(num); i++){
        if (num%i==0)
            check++; 
        }
        if(check==0){
            return true;    
        }
        else{
            return false;
        }
}

int main(void) {
for(int i = 0; i <= 21; i++)
if(isPrime(i))
cout << i << " ";
cout << endl;
return 0;
}
