#include <iostream>

// ==========================================
// Базовий клас: Tree (Спільний інтерфейс)
// ==========================================
class Tree {
public:
    // Віртуальний метод для малювання
    virtual void draw() const {
        std::cout << "Base Tree" << std::endl;
    }

    // Віртуальний деструктор для коректного очищення пам'яті
    virtual ~Tree() {}
};

// ==========================================
// Похідний клас 1: Проста ялинка (Slash Tree)
// ==========================================
class SlashTree : public Tree {
public:
    void draw() const override {
        std::cout << "Drawing 1:\n";
        std::cout << "  /\\\n";
        std::cout << " //\\\\\n";
    }
};

// ==========================================
// Похідний клас 2: Ялинка із зірочками (Star Tree)
// ==========================================
class StarTree : public Tree {
public:
    void draw() const override {
        std::cout << "Drawing 2:\n";
        std::cout << "  /\\\n";
        std::cout << " /**\\\n";
    }
};

// ==========================================
// Похідний клас 3: Ялинка з плюсиками (Plus Tree)
// ==========================================
class PlusTree : public Tree {
public:
    void draw() const override {
        std::cout << "Drawing 3:\n";
        std::cout << "  /\\\n";
        std::cout << " /++\\\n";
    }
};

// ==========================================
// Головна функція програми
// ==========================================
int main() {
    // 1. Створюємо три об'єкти різних типів дерев
    SlashTree tree1;
    StarTree  tree2;
    PlusTree  tree3;

    // 2. Створюємо таблицю (масив) із 3-х вказівників на базовий клас Tree
    Tree* forest[3];

    // 3. Призначаємо вказівники на наші конкретні об'єкти коміркам масиву
    forest[0] = &tree1;
    forest[1] = &tree2;
    forest[2] = &tree3;

    std::cout << "--- START POLYMORPHIC DRAWING ---\n\n";

    // 4. Цикл 'for', який ітерує по масиву та викликає метод draw()
    for (int i = 0; i < 3; i++) {
        forest[i]->draw();
        std::cout << "\n"; // Додатковий відступ між малюнками
    }

    return 0;
}
