#include <iostream>
#include <string>
#include <ctime>
#include <cstdlib>
#include <iomanip>
using namespace std;

bool isLeap(int year) {
        if(year%4==0 && year % 100 != 0 or year % 400 == 0){
            return true;
        }
        else{
           return false;
        }
}
int main(void) {
for(int yr = 2000; yr < 2002; yr++) {
    switch(isLeap(yr)){
        case false:
            cout<<"31 28 31 30 31 30 31 31 30 31 30 31";
            cout<<endl;
            break;
        case true:
            cout<<"31 29 31 30 31 30 31 31 30 31 30 31";
            cout<<endl;
            break;
    }
return 0;
}
