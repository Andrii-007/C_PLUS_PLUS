#include <iostream>
#include <ctime>
#include <iostream>

using namespace std;

struct Date {
    int year;
    int month;
    int day;
};

Date today(void) {
    time_t t = time(NULL);
    tm tl = *localtime(&t);

    Date d; 
    d.year = tl.tm_year + 1900; 
    d.month = tl.tm_mon + 1;
    d.day = tl.tm_mday;

    return d; 
}

Date birthday(void) {
    Date d; 
    d.year ; 
    d.month;
    d.day;

    return d; 
}

bool isLeap(int year) {
        if(year%4==0 && year % 100 != 0 or year % 400 == 0){
            return true;
        }
        else{
           return false;
        }
}

int monthLength(int year, int month) {
    switch (month) {
        case 1: case 3: case 5: case 7: case 8: case 10: case 12:
            return 31;

        case 4: case 6: case 9: case 11:
            return 30;

        case 2:
            if (isLeap(year)) 
                return 29;
            else 
                return 28;

    }
}


