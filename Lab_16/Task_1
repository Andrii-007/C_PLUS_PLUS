int days=0;
if(b.year!=t.year){
for (int yr = b.year+1; yr < t.year; yr++) {
        for (int mo = 1; mo <= 12; mo++) {
            days+=monthLength(yr, mo);
        }
    }
    
for (int mo = b.month+1; mo <= 12; mo++) {
            days+=monthLength(b.year, mo);
        }
   
